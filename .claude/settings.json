{
  "permissions": {
    "allow": [
      "Bash(uv run pytest:*)",
      "Bash(uvx ruff:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/ruff-format.sh\""
          }
        ]
      }
    ]
  }
}
